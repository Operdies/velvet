{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "attach",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/debug/vv",
      "args": [ "attach", "-S", "debug" ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "make debug",
      "console": "externalTerminal",
      "initCommands": [
        "command source ${workspaceFolder}/scripts/lldb-config"
      ]
    },
    {
      "name": "chunk",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/debug/vv",
      "args": [ "--socket", "debug", "lua", "-" ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "make debug",
      "initCommands": [
        "command source ${workspaceFolder}/scripts/lldb-config"
      ]
    },
    {
      "name": "foreground",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/debug/vv",
      "args": [ "foreground", "--socket", "debug" ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "make debug",
      "console": "integratedTerminal",
      "initCommands": [
        "command source ${workspaceFolder}/scripts/lldb-config"
      ]
    },
    {
      "name": "Debug tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/debug/test",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "make debug",
      "console": "integratedTerminal",
      "initCommands": [
        "command source ${workspaceFolder}/scripts/lldb-config"
      ]
    }
  ]
}
