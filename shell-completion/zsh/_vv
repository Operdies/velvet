#compdef vv

_vv_sockets() {
  local socket_dir="$HOME/.local/share/velvet/sockets"
  if [[ -d "$socket_dir" ]]; then
    compadd -- "$socket_dir"/*(N:t)
  fi
}

_vv_commands() {
  # TODO: query commands from the server
  local -a commands=(
    'quit:Quit the velvet session, killing all windows'
    'reload:Reload the velvet session, resourcing configs'
    'detach:Detach the current terminal from the session'
    'spawn:Spawn a new window running the provided command'
  )
  _describe 'command' commands
}

_vv() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s \
    '(-S --socket)'{-S,--socket}'[Specify the socket to use]:socket name:_vv_sockets' \
    '(--version -v)'{--version,-v}'[Print version and exit]' \
    '(-h --help)'{-h,--help}'[Show help text and exit]' \
    '1:command:->cmd' \
    '*:: :->args' && return

  case $state in
    cmd)
      local -a builtins=(
        'attach:Attach to a velvet session'
        'lua:Execute a lua file or stdin on the server'
      )
      _describe 'builtin' builtins
      _vv_commands
      ;;
    args)
      case $line[1] in
        lua)
          _arguments \
            '1:lua file or -:_files' \
            '*:arguments:' && return
          ;;
        spawn)
          shift words
          (( CURRENT-- ))
          _normal && return
          ;;
      esac
      ;;
  esac
}

_vv "$@"
