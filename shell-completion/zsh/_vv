#compdef vv

_arguments -C \
  '(-S --socket)'{-S,--socket}'[Specify the socket to use]:socket path:_files' \
  '(-h --help)'{-h,--help}'[Show help and exit]' \
  '1:mode:->mode' \
  '*:argument:->args' \
  && return

case $state in
  mode)
    local -a modes
    modes=(
      'attach:Attach to the server at <socket> or $VELVET'
      'lua:Evaluate <file> or stdin on the server'
      'foreground:Start a velvet session without daemonizing'
      'quit:Quit the velvet session, killing all windows'
      'detach:Detach the current terminal from the session'
      'reload:Reload the velvet session, resourcing configs'
    )
    _describe 'mode' modes
    ;;
  args)
    case $words[2] in
      lua)
        _arguments '2:lua file:_files -g "*.lua"'
        ;;
    esac
    ;;
esac

